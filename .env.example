# OpenAI API Key (required for Vision AI image analysis)
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Server
PORT=3001

# CORS – optional comma-separated EXTRA origins (staging, ngrok, etc.).
# merch7am.com, www, myshopify.com, and localhost dev ports are always allowed in code.
# Do not rely on CORS_ORIGIN=* ; Shopify may use credentialed fetch which rejects ACAO:*.
# CORS_ORIGIN=https://staging.example.com

# Estimate emails (Resend - https://resend.com)
# Get API key at https://resend.com/api-keys
# Verify your domain for production, or use onboarding@resend.dev for testing
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
ADMIN_EMAIL=admin@merch7am.com

# Brief corporativo (modal → POST /api/corp-brief, envío con Resend)
# Opcional: destinatario distinto del de cotizaciones (si no se define, usa ADMIN_EMAIL)
# BRIEF_TO_EMAIL=briefer@merch7am.com
# Opcional: si se define, el JSON del formulario debe incluir form_token con el mismo valor
# BRIEF_FORM_SECRET=
# ESTIMATES_DIR=data/estimates

# Company report (every 2 weeks) - email to receive the list
REPORT_EMAIL=reportes@merch7am.com
# Token to trigger report via GET /api/reports/companies?token=xxx (for cron services)
REPORT_TOKEN=your-secret-token-here

# Chatbot (FAQs + product recommendations)
# Uses same OPENAI_API_KEY. Model: gpt-4o-mini (faster, cheaper) or gpt-4o
CHAT_MODEL=gpt-4o-mini

# Shopify Storefront API - for product recommendations in chat
# Create a Storefront API token in Shopify Admin > Settings > Apps and sales channels > Develop apps
SHOPIFY_STORE_DOMAIN=merch7am.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=
# Optional: custom store URL for product links (default: https://SHOPIFY_STORE_DOMAIN)
SHOPIFY_STORE_URL=https://merch7am.com

# --- Agents ---
# Weekly Performance Digest: recipient email (falls back to REPORT_EMAIL then ADMIN_EMAIL)
DIGEST_EMAIL=digest@merch7am.com
# Shared token for all agent HTTP triggers (reuses REPORT_TOKEN if not set)
# AGENT_TOKEN=your-secret-token-here
#
# Cron — send digest every Monday at 9am:
#   0 9 * * 1 cd /path/to/merch-ai/backend && python -m scripts.send_performance_digest
